@model IEnumerable<SchoolManager.ViewModels.ReporteCatalogoItemViewModel>
@{
    ViewData["Title"] = "Reportes Institucionales";
    Layout = "_AdminLayout";
    var catalogo = ViewBag.Catalogo as List<SchoolManager.ViewModels.ReporteCatalogoItemViewModel> ?? new();
    var esDocente = ViewBag.EsDocente as bool? == true;
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="mb-2"><i class="bi bi-file-earmark-bar-graph"></i> Reportes Institucionales</h2>
            <p class="text-muted mb-0">
                @if (esDocente)
                {
                    <text>Plantillas oficiales alineadas a sus asignaciones docentes (mismo alcance que el portal de notas).</text>
                }
                else
                {
                    <text>Plantillas oficiales del instituto para consejería, calificaciones y carpetas académicas.</text>
                }
            </p>
        </div>
    </div>

    <div class="row g-4">
        @foreach (var item in catalogo)
        {
            <div class="col-md-6 col-xl-4">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex align-items-start mb-3">
                            <div class="rounded-circle bg-primary bg-opacity-10 p-3 me-3">
                                <i class="bi @item.Icono text-primary fs-4"></i>
                            </div>
                            <div>
                                <h5 class="card-title mb-1">@item.Titulo</h5>
                                <p class="card-text text-muted small mb-0">@item.Descripcion</p>
                            </div>
                        </div>
                        <div class="mt-auto">
                            <a href="@Url.Action(item.Action, item.Controller)" class="btn btn-primary w-100">
                                <i class="bi bi-box-arrow-in-right"></i> Abrir reporte
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
