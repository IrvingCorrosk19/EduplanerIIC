@model SchoolManager.ViewModels.CalificacionesTecnologiaReportViewModel
@using SchoolManager.ViewModels
@{
    Layout = null;
    string Fn(decimal? n) => CalificacionesTecnologiaFilaViewModel.FormatearNota(n);
    var area1 = Model.Areas.Count > 0 ? Model.Areas[0] : "CONTABILIDAD";
    var area2 = Model.Areas.Count > 1 ? Model.Areas[1] : "EDUC. HOGAR";
    var area3 = Model.Areas.Count > 2 ? Model.Areas[2] : "ART. INDUSTRIALES";
    var trim1 = Model.TrimestresEncabezado.Count > 0 ? Model.TrimestresEncabezado[0] : "I- TRIMESTRE ";
    var trim2 = Model.TrimestresEncabezado.Count > 1 ? Model.TrimestresEncabezado[1] : "II- TRIMESTRE ";
    var trim3 = Model.TrimestresEncabezado.Count > 2 ? Model.TrimestresEncabezado[2] : "III- TRIMESTRE ";
    string LogoSrc(string? url)
    {
        if (string.IsNullOrWhiteSpace(url)) return "";
        if (url.StartsWith("http://", StringComparison.OrdinalIgnoreCase) ||
            url.StartsWith("https://", StringComparison.OrdinalIgnoreCase))
            return url;
        return Url.Content($"/File/GetSchoolLogo?logoUrl={Uri.EscapeDataString(url)}") ?? "";
    }
    var logoSrc = LogoSrc(Model.LogoUrl);
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Calificaciones de Tecnología</title>
    <link rel="stylesheet" href="~/css/reporte-institucional-base.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/reporte-calificaciones-tecnologia.css" asp-append-version="true" />
    <style>@@media print { @@page { size: landscape; } }</style>
</head>
<body class="reporte-institucional-body reporte-tecnologia-body">
    <div class="reporte-institucional-toolbar no-print">
        <button type="button" onclick="window.print()">Imprimir</button>
        <button type="button" onclick="window.close()">Cerrar</button>
    </div>

    <div id="printArea">
        <header class="rt-header">
            @if (!string.IsNullOrEmpty(logoSrc))
            {
                <div class="rt-header-logo">
                    <img src="@logoSrc" alt="Logo institucional" onerror="this.parentElement.style.display='none'" />
                </div>
            }
            else
            {
                <div class="rt-header-logo"></div>
            }
            <div class="rt-header-text">
                <span class="line">@Model.MinisterioLinea</span>
                <span class="line instituto">@Model.InstitutoNombre</span>
                <span class="line">@Model.TituloInforme</span>
            </div>
        </header>

        <table class="rt-meta" aria-label="Datos del informe">
            <tr>
                <td class="meta-consejero">Consejero (a): @Model.ConsejeroNombre</td>
                <td class="meta-asignatura">@Model.AsignaturaLinea</td>
                <td class="meta-grupo">GRUPO: @Model.GrupoEtiqueta</td>
            </tr>
        </table>

        <table class="rt-tabla" aria-label="Calificaciones de tecnología">
            <thead>
                <tr class="rt-head-row rt-head-trimestres">
                    <th class="rt-col-num th-numero" rowspan="2">N°</th>
                    <th class="rt-col-nombre th-nombre" rowspan="2">NOMBRE DE LOS ESTUDIANTES</th>
                    <th class="rt-col-trim-group" colspan="3">@trim1</th>
                    <th class="rt-col-trim-group" colspan="3">@trim2</th>
                    <th class="rt-col-trim-group" colspan="3">@trim3</th>
                    <th class="rt-col-promedio vertical-header" rowspan="2">PROMEDIO FINAL</th>
                </tr>
                <tr class="rt-head-row rt-head-materias">
                    <th class="rt-col-nota vertical-header">@area1</th>
                    <th class="rt-col-nota vertical-header">@area2</th>
                    <th class="rt-col-nota vertical-header">@area3</th>
                    <th class="rt-col-nota vertical-header">@area1</th>
                    <th class="rt-col-nota vertical-header">@area2</th>
                    <th class="rt-col-nota vertical-header">@area3</th>
                    <th class="rt-col-nota vertical-header">@area1</th>
                    <th class="rt-col-nota vertical-header">@area2</th>
                    <th class="rt-col-nota vertical-header">@area3</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var f in Model.Filas)
                {
                    <tr>
                        <td class="rt-col-num">@f.Numero</td>
                        <td class="rt-col-nombre">@f.Nombre</td>
                        <td>@Fn(f.NotaT1Area1)</td>
                        <td>@Fn(f.NotaT1Area2)</td>
                        <td>@Fn(f.NotaT1Area3)</td>
                        <td>@Fn(f.NotaT2Area1)</td>
                        <td>@Fn(f.NotaT2Area2)</td>
                        <td>@Fn(f.NotaT2Area3)</td>
                        <td>@Fn(f.NotaT3Area1)</td>
                        <td>@Fn(f.NotaT3Area2)</td>
                        <td>@Fn(f.NotaT3Area3)</td>
                        <td>@Fn(f.PromedioFinal)</td>
                    </tr>
                }
                @for (var v = 0; v < Model.FilasPlantillaVacias; v++)
                {
                    var n = Model.Filas.Count + v + 1;
                    <tr>
                        <td class="rt-col-num">@n</td>
                        <td class="rt-col-nombre"></td>
                        <td></td><td></td><td></td>
                        <td></td><td></td><td></td>
                        <td></td><td></td><td></td>
                        <td></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</body>
</html>
