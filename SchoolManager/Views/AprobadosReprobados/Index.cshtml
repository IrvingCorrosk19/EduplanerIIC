@model SchoolManager.ViewModels.AprobadosReprobadosFiltroViewModel
@{
    ViewData["Title"] = "Cuadro de Aprobados y Reprobados";
    Layout = "_AdminLayout";
    var trimestres = ViewBag.TrimestresDisponibles as List<string>;
    var esDocente = ViewBag.EsDocente as bool? == true;
    var textoTodasMaterias = esDocente ? "Todas mis materias" : "Todas las materias";
    var textoTodosGrupos = esDocente ? "Todos mis grupos" : "Todos los grupos";
    var textoTodosNiveles = esDocente ? "Todos mis niveles" : "Todos los niveles";
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="mb-3">
                <i class="bi bi-bar-chart-fill"></i> Cuadro de Aprobados y Reprobados por Grado
            </h2>
            <p class="text-muted">
                @if (esDocente)
                {
                    <text>Solo verá <strong>sus asignaciones</strong> (las mismas del portal de notas). Elija nivel, trimestre, materia y grupo; puede usar <strong>Todos</strong> en cada filtro dentro de su alcance.</text>
                }
                else
                {
                    <text>Filtros por trimestre, materia y grupo de la escuela. Puede elegir <strong>Todos</strong> en cada filtro para varias asignaciones en un solo reporte.</text>
                }
            </p>
        </div>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card mb-4">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="bi bi-funnel"></i> Filtros del Reporte</h5>
        </div>
        <div class="card-body">
            <form id="filtro-form">
                @Html.AntiForgeryToken()
                <div class="row">
                    <div class="col-md-6 col-lg-3">
                        <div class="mb-3">
                            <label class="form-label"><strong>Nivel:</strong> <span class="text-danger">*</span></label>
                            <select class="form-select" id="nivelEducativo" name="NivelEducativo" required>
                                <option value="">-- Seleccione un nivel --</option>
                            </select>
                            <small class="text-muted">Premedia (7°–9°) o Media (10°–12°) según sus asignaciones.</small>
                        </div>
                    </div>

                    <div class="col-md-6 col-lg-3">
                        <div class="mb-3">
                            <label class="form-label"><strong>Trimestre:</strong> <span class="text-danger">*</span></label>
                            <select class="form-select" id="trimestre" name="Trimestre" required>
                                <option value="">-- Seleccione un trimestre --</option>
                                <option value="@SchoolManager.ViewModels.AprobadosReprobadosFiltroValores.Todos">Todos los trimestres</option>
                                @if (trimestres != null)
                                {
                                    foreach (var trimestre in trimestres)
                                    {
                                        <option value="@trimestre">@trimestre</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>

                    <div class="col-md-6 col-lg-3">
                        <div class="mb-3">
                            <label class="form-label"><strong>Materia:</strong> <span class="text-danger">*</span></label>
                            <select class="form-select" id="materiaId" name="MateriaId" required disabled>
                                <option value="">-- Seleccione primero el nivel --</option>
                            </select>
                        </div>
                    </div>

                    <div class="col-md-6 col-lg-3">
                        <div class="mb-3">
                            <label class="form-label"><strong>Grupo:</strong> <span class="text-danger">*</span></label>
                            <select class="form-select" id="grupoCombo" required disabled>
                                <option value="">-- Seleccione primero la materia --</option>
                            </select>
                            <input type="hidden" id="groupId" name="GroupId" />
                            <input type="hidden" id="gradeLevelId" name="GradeLevelId" />
                            <small class="text-muted">Formato: nivel académico + nombre (ej. 9 G).</small>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-12 text-center">
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="bi bi-file-earmark-bar-graph"></i> Generar Reporte
                        </button>
                        <button type="button" class="btn btn-outline-secondary btn-lg" id="btn-limpiar">
                            <i class="bi bi-arrow-clockwise"></i> Limpiar
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div id="reporte-container" style="display: none;">
        <div class="card">
            <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-graph-up"></i> Reporte Generado</h5>
                <div>
                    <button type="button" class="btn btn-light btn-sm" onclick="window.print()">
                        <i class="bi bi-printer"></i> Imprimir
                    </button>
                    <a href="#" id="btn-exportar-pdf" class="btn btn-light btn-sm">
                        <i class="bi bi-file-pdf"></i> Exportar PDF
                    </a>
                    <button type="button" class="btn btn-light btn-sm" id="btn-vista-previa">
                        <i class="bi bi-eye"></i> Vista Completa
                    </button>
                </div>
            </div>
            <div class="card-body" id="reporte-content"></div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            const TODOS = '@SchoolManager.ViewModels.AprobadosReprobadosFiltroValores.Todos';
            const GUID_VACIO = '00000000-0000-0000-0000-000000000000';
            const TEXTO_TODAS_MATERIAS = '@textoTodasMaterias';
            const TEXTO_TODOS_GRUPOS = '@textoTodosGrupos';
            const TEXTO_TODOS_NIVELES = '@textoTodosNiveles';

            cargarNiveles();

            function cargarNiveles() {
                $.get('@Url.Action("ObtenerNivelesFiltro", "AprobadosReprobados")')
                    .done(function (response) {
                        const select = $('#nivelEducativo');
                        select.html('<option value="">-- Seleccione un nivel --</option>');
                        select.append(`<option value="${TODOS}">${TEXTO_TODOS_NIVELES}</option>`);
                        if (response.success && response.data) {
                            response.data.forEach(function (n) {
                                select.append(`<option value="${n}">${n}</option>`);
                            });
                        }
                    });
            }

            function resetMateriaYGrupo() {
                $('#materiaId').prop('disabled', true)
                    .html('<option value="">-- Seleccione primero el nivel --</option>');
                $('#grupoCombo').prop('disabled', true)
                    .html('<option value="">-- Seleccione primero la materia --</option>');
                $('#groupId, #gradeLevelId').val('');
            }

            function cargarMaterias(nivelEducativo) {
                const select = $('#materiaId');
                select.prop('disabled', true).html('<option value="">Cargando materias...</option>');

                $.get('@Url.Action("ObtenerMateriasFiltro", "AprobadosReprobados")', { nivelEducativo: nivelEducativo })
                    .done(function (response) {
                        select.html('<option value="">-- Seleccione una materia --</option>');
                        select.append(`<option value="${GUID_VACIO}">${TEXTO_TODAS_MATERIAS}</option>`);
                        if (response.success && response.data) {
                            response.data.forEach(function (m) {
                                select.append(`<option value="${m.id}">${m.nombre}</option>`);
                            });
                            select.prop('disabled', false);
                        } else {
                            select.html('<option value="">Sin materias para este nivel</option>');
                        }
                    });
            }

            function esTodasMaterias(materiaId) {
                return !materiaId || materiaId === GUID_VACIO;
            }

            function cargarGrupos(materiaId) {
                const grupoSelect = $('#grupoCombo');
                const nivelEducativo = $('#nivelEducativo').val();
                const idConsulta = esTodasMaterias(materiaId) ? GUID_VACIO : materiaId;

                if (!nivelEducativo) return;

                grupoSelect.prop('disabled', true).html('<option value="">Cargando grupos...</option>');

                $.get('@Url.Action("ObtenerGruposFiltro", "AprobadosReprobados")', {
                    materiaId: idConsulta,
                    nivelEducativo: nivelEducativo
                })
                    .done(function (response) {
                        grupoSelect.html(`<option value="${TODOS}">${TEXTO_TODOS_GRUPOS}</option>`);
                        if (response.success && response.data) {
                            const todas = esTodasMaterias(materiaId);
                            response.data.forEach(function (g) {
                                const val = todas && g.subjectId
                                    ? `${g.subjectId}|${g.groupId}|${g.gradeLevelId}`
                                    : `${g.groupId}|${g.gradeLevelId}`;
                                grupoSelect.append(`<option value="${val}">${g.nombre}</option>`);
                            });
                            grupoSelect.prop('disabled', false);
                        } else {
                            grupoSelect.html('<option value="">Sin grupos para este filtro</option>');
                        }
                    });
            }

            function aplicarSeleccionGrupo(val) {
                $('#groupId, #gradeLevelId').val('');
                if (!val || val === TODOS) return;
                const parts = val.split('|');
                if (parts.length === 3) {
                    $('#groupId').val(parts[1]);
                    $('#gradeLevelId').val(parts[2]);
                } else if (parts.length === 2) {
                    $('#groupId').val(parts[0]);
                    $('#gradeLevelId').val(parts[1]);
                }
            }

            function resolverMateriaIdParaEnvio() {
                let materiaId = $('#materiaId').val();
                const grupoVal = $('#grupoCombo').val();
                if (grupoVal && grupoVal !== TODOS) {
                    const parts = grupoVal.split('|');
                    if (parts.length === 3) materiaId = parts[0];
                }
                return esTodasMaterias(materiaId) ? GUID_VACIO : materiaId;
            }

            function resolverIdsGrupoParaEnvio() {
                const grupoVal = $('#grupoCombo').val();
                if (!grupoVal || grupoVal === TODOS) {
                    return { groupId: GUID_VACIO, gradeLevelId: GUID_VACIO };
                }
                const parts = grupoVal.split('|');
                if (parts.length === 3) {
                    return { groupId: parts[1], gradeLevelId: parts[2] };
                }
                return { groupId: parts[0], gradeLevelId: parts[1] };
            }

            $('#nivelEducativo').change(function () {
                resetMateriaYGrupo();
                const nivel = $(this).val();
                if (!nivel) return;
                cargarMaterias(nivel);
            });

            $('#materiaId').change(function () {
                const materiaId = $(this).val();
                const grupoSelect = $('#grupoCombo');
                $('#groupId, #gradeLevelId').val('');

                if (!materiaId) {
                    grupoSelect.prop('disabled', true).html('<option value="">-- Seleccione primero la materia --</option>');
                    return;
                }

                cargarGrupos(materiaId);
            });

            $('#grupoCombo').change(function () {
                aplicarSeleccionGrupo($(this).val());
            });

            $('#filtro-form').submit(function (e) {
                e.preventDefault();

                const trimestre = $('#trimestre').val();
                const nivelEducativo = $('#nivelEducativo').val();
                const materiaId = resolverMateriaIdParaEnvio();
                const idsGrupo = resolverIdsGrupoParaEnvio();

                if (!nivelEducativo) {
                    Swal.fire('Error', 'Seleccione un nivel educativo o "Todos mis niveles"', 'error');
                    return;
                }

                if (!trimestre) {
                    Swal.fire('Error', 'Seleccione un trimestre o "Todos los trimestres"', 'error');
                    return;
                }

                if (!$('#materiaId').val()) {
                    Swal.fire('Error', 'Seleccione una materia o "Todas las materias"', 'error');
                    return;
                }

                if (!$('#grupoCombo').val()) {
                    Swal.fire('Error', 'Seleccione un grupo o "Todos los grupos"', 'error');
                    return;
                }

                Swal.fire({
                    title: 'Generando reporte...',
                    allowOutsideClick: false,
                    didOpen: () => Swal.showLoading()
                });

                $.ajax({
                    url: '@Url.Action("GenerarReporte", "AprobadosReprobados")',
                    type: 'POST',
                    timeout: 90000,
                    data: {
                        Trimestre: trimestre,
                        NivelEducativo: nivelEducativo,
                        MateriaId: materiaId,
                        GroupId: idsGrupo.groupId,
                        GradeLevelId: idsGrupo.gradeLevelId,
                        __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function (response) {
                        Swal.close();
                        if (response.success) {
                            mostrarReporte(response.data);
                            $('#reporte-container').slideDown();
                        } else {
                            Swal.fire('Error', response.message, 'error');
                        }
                    },
                    error: function () {
                        Swal.close();
                        Swal.fire('Error', 'No se pudo generar el reporte', 'error');
                    }
                });
            });

            $('#btn-limpiar').click(function () {
                $('#filtro-form')[0].reset();
                resetMateriaYGrupo();
                $('#reporte-container').slideUp();
                cargarNiveles();
            });

            function buildExportUrl(action) {
                const trimestre = $('#trimestre').val();
                const nivelEducativo = $('#nivelEducativo').val();
                const materiaId = resolverMateriaIdParaEnvio();
                const idsGrupo = resolverIdsGrupoParaEnvio();
                return action +
                    '?trimestre=' + encodeURIComponent(trimestre) +
                    '&nivelEducativo=' + encodeURIComponent(nivelEducativo) +
                    '&materiaId=' + encodeURIComponent(materiaId) +
                    '&groupId=' + encodeURIComponent(idsGrupo.groupId) +
                    '&gradeLevelId=' + encodeURIComponent(idsGrupo.gradeLevelId);
            }

            function validarFiltrosExportacion() {
                if (!$('#nivelEducativo').val()) {
                    Swal.fire('Aviso', 'Seleccione nivel (o todos).', 'warning');
                    return false;
                }
                if (!$('#trimestre').val()) {
                    Swal.fire('Aviso', 'Seleccione trimestre (o todos).', 'warning');
                    return false;
                }
                if (!$('#materiaId').val()) {
                    Swal.fire('Aviso', 'Seleccione materia (o todas).', 'warning');
                    return false;
                }
                if (!$('#grupoCombo').val()) {
                    Swal.fire('Aviso', 'Seleccione grupo (o todos).', 'warning');
                    return false;
                }
                return true;
            }

            $(document).on('click', '#btn-vista-previa', function () {
                if (!validarFiltrosExportacion()) return;
                window.open(buildExportUrl('@Url.Action("VistaPrevia", "AprobadosReprobados")'), '_blank');
            });

            $(document).on('click', '#btn-exportar-pdf', function (e) {
                e.preventDefault();
                if (!validarFiltrosExportacion()) return;
                window.location.href = buildExportUrl('@Url.Action("ExportarPdf", "AprobadosReprobados")');
            });

            function mostrarReporte(data) {
                const colMateria = data.mostrarColumnaMateria
                    ? '<th rowspan="2">Materia</th>'
                    : '';
                const colspanVacio = data.mostrarColumnaMateria ? 14 : 13;

                let html = `
                    <div class="text-center mb-4">
                        <h4>${data.institutoNombre}</h4>
                        <h5>CUADRO DE APROBADOS Y REPROBADOS</h5>
                        <p><strong>Profesor(a):</strong> ${data.profesorCoordinador}</p>
                        <p><strong>Trimestre:</strong> ${data.trimestre} | <strong>Filtro:</strong> ${data.nivelEducativo}</p>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-bordered table-hover">
                            <thead class="table-dark">
                                <tr class="text-center">
                                    ${colMateria}
                                    <th rowspan="2">Grado</th>
                                    <th rowspan="2">Grupo</th>
                                    <th rowspan="2">Total</th>
                                    <th colspan="2">Aprobados</th>
                                    <th colspan="2">Reprobados</th>
                                    <th colspan="2">Rep. hasta la fecha</th>
                                    <th colspan="2">Sin calificaciones</th>
                                    <th colspan="2">Retirados</th>
                                </tr>
                                <tr class="text-center">
                                    <th>#</th><th>%</th><th>#</th><th>%</th><th>#</th><th>%</th><th>#</th><th>%</th><th>#</th><th>%</th>
                                </tr>
                            </thead>
                            <tbody>`;

                if (!data.estadisticas || data.estadisticas.length === 0) {
                    html += `<tr><td colspan="${colspanVacio}" class="text-center py-4 text-muted">No hay datos para los filtros seleccionados.</td></tr>`;
                } else {
                    data.estadisticas.forEach(function (est) {
                        const tdMateria = data.mostrarColumnaMateria
                            ? `<td class="text-center">${est.materia || ''}</td>`
                            : '';
                        html += `<tr>
                            ${tdMateria}
                            <td class="text-center"><strong>${est.grado}</strong></td>
                            <td class="text-center">${est.grupo}</td>
                            <td class="text-center"><strong>${est.totalEstudiantes}</strong></td>
                            <td class="text-center text-success">${est.aprobados}</td>
                            <td class="text-center">${est.porcentajeAprobados.toFixed(2)}%</td>
                            <td class="text-center text-danger">${est.reprobados}</td>
                            <td class="text-center">${est.porcentajeReprobados.toFixed(2)}%</td>
                            <td class="text-center">${est.reprobadosHastaLaFecha}</td>
                            <td class="text-center">${est.porcentajeReprobadosHastaLaFecha.toFixed(2)}%</td>
                            <td class="text-center">${est.sinCalificaciones}</td>
                            <td class="text-center">${est.porcentajeSinCalificaciones.toFixed(2)}%</td>
                            <td class="text-center">${est.retirados}</td>
                            <td class="text-center">${est.porcentajeRetirados.toFixed(2)}%</td>
                        </tr>`;
                    });
                }

                const t = data.totalesGenerales;
                const colspanTotales = data.mostrarColumnaMateria ? 3 : 2;
                html += `<tr class="table-primary">
                    <td colspan="${colspanTotales}" class="text-center"><strong>TOTALES</strong></td>
                    <td class="text-center"><strong>${t.totalEstudiantes}</strong></td>
                    <td class="text-center text-success"><strong>${t.totalAprobados}</strong></td>
                    <td class="text-center"><strong>${t.porcentajeAprobados.toFixed(2)}%</strong></td>
                    <td class="text-center text-danger"><strong>${t.totalReprobados}</strong></td>
                    <td class="text-center"><strong>${t.porcentajeReprobados.toFixed(2)}%</strong></td>
                    <td class="text-center"><strong>${t.totalReprobadosHastaLaFecha}</strong></td>
                    <td class="text-center"><strong>${t.porcentajeReprobadosHastaLaFecha.toFixed(2)}%</strong></td>
                    <td class="text-center"><strong>${t.totalSinCalificaciones}</strong></td>
                    <td class="text-center"><strong>${t.porcentajeSinCalificaciones.toFixed(2)}%</strong></td>
                    <td class="text-center"><strong>${t.totalRetirados}</strong></td>
                    <td class="text-center"><strong>${t.porcentajeRetirados.toFixed(2)}%</strong></td>
                </tr></tbody></table></div>`;

                $('#reporte-content').html(html);
            }
        });
    </script>
}
