@model SchoolManager.ViewModels.AprobadosReprobadosReportViewModel

@{

    ViewData["Title"] = "Reporte de Aprobados y Reprobados";

    Layout = null;

    var autoPrint = string.Equals(Context.Request.Query["autoprint"], "1", StringComparison.Ordinal);

    var fechaGeneracion = TimeZoneService.ToLocalDisplayString(Model.FechaGeneracion, "dd/MM/yyyy HH:mm");

    var esConsolidado = Model.EsConsolidado;

}



<!DOCTYPE html>

<html lang="es">

<head>

    <meta charset="utf-8" />

    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"]</title>

    <link rel="stylesheet" href="~/lib/bootstrap/css/bootstrap.min.css" />

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" />

    <link rel="stylesheet" href="~/css/aprobados-reprobados-vista-previa.css" asp-append-version="true" />

    <style>

        @@page {

            size: @(esConsolidado ? "A4 landscape" : "A4 portrait");

            margin: 10mm 10mm 18mm 10mm;

        }

    </style>

</head>

<body class="apr-vista-previa @(esConsolidado ? "apr-consolidado" : "")">

    <div class="apr-toolbar no-print">

        <button type="button" onclick="window.print()" class="btn btn-primary btn-sm">

            <i class="bi bi-printer"></i> Imprimir

        </button>

        <button type="button" onclick="window.close()" class="btn btn-secondary btn-sm">

            <i class="bi bi-x-circle"></i> Cerrar

        </button>

    </div>



    <div class="apr-print-hint no-print" role="note">

        <strong>Impresión profesional:</strong>

        En el diálogo de impresión de Chrome o Edge, desactive la opción

        <strong>«Encabezados y pies de página»</strong> para eliminar la URL del navegador

        (<code>eduplaner.net/AprobadosReprobados/VistaPrevia…</code>) y la numeración automática del navegador.

        El pie institucional de EduPlanner aparecerá en su lugar.

    </div>



    <div id="printArea" class="apr-document">

        <div class="apr-running-header" aria-hidden="true">

            <p class="apr-line-ministerio mb-0">Ministerio de Educación</p>

            <p class="apr-line-regional mb-0">Dirección Regional de San Miguelito</p>

            <p class="apr-line-institucion mb-0">@Model.InstitutoNombre</p>

            <p class="apr-line-titulo mb-0">Cuadro de Aprobados y Reprobados por Grado — @Model.Trimestre — @Model.AnoLectivo</p>

        </div>



        <div class="apr-print-body">

            <header class="apr-header">

                <div class="apr-header-grid">

                    @if (!string.IsNullOrEmpty(Model.LogoUrl))

                    {

                        <div class="apr-header-logo-cell">

                            <img src="@Model.LogoUrl" alt="Logo institucional" class="apr-header-logo" onerror="this.parentElement.style.display='none'" />

                        </div>

                    }

                    <div class="apr-header-text-cell">

                        <p class="apr-line-ministerio">Ministerio de Educación</p>

                        <p class="apr-line-regional">Dirección Regional de San Miguelito</p>

                        <p class="apr-line-institucion">@Model.InstitutoNombre</p>

                        <p class="apr-line-titulo">Cuadro de Aprobados y Reprobados por Grado</p>

                        @if (esConsolidado)

                        {

                            <span class="apr-badge-consolidado">

                                Reporte consolidado — @Model.CantidadAsignaciones asignaciones

                            </span>

                        }

                    </div>

                </div>

            </header>



            <section class="apr-meta">

                <div class="apr-meta-row">

                    <div class="apr-meta-cell">

                        <span class="apr-meta-label">Coordinador(a)</span>

                        <span class="apr-meta-value">@Model.ProfesorCoordinador</span>

                    </div>

                    <div class="apr-meta-cell">

                        <span class="apr-meta-label">Trimestre</span>

                        <span class="apr-meta-value">@Model.Trimestre</span>

                    </div>

                    <div class="apr-meta-cell">

                        <span class="apr-meta-label">Año lectivo</span>

                        <span class="apr-meta-value">@Model.AnoLectivo</span>

                    </div>

                    <div class="apr-meta-cell">

                        <span class="apr-meta-label">Alcance</span>

                        <span class="apr-meta-value">@Model.NivelEducativo</span>

                    </div>

                </div>

            </section>



            @if (Model.Estadisticas != null && Model.Estadisticas.Any())

            {

                @await Html.PartialAsync("_TablaReporte", Model)



                <section class="apr-firmas">

                    <div class="apr-firma-cell">

                        <div class="apr-firma-linea"></div>

                        <p class="apr-firma-titulo">Profesor(a) Coordinador(a)</p>

                    </div>

                    <div class="apr-firma-cell">

                        <div class="apr-firma-linea"></div>

                        <p class="apr-firma-titulo">Director(a)</p>

                    </div>

                </section>



                <footer class="apr-pie-institucional">

                    <div class="apr-pie-grid">

                        <span class="apr-pie-izq">Sistema EduPlanner</span>

                        <span class="apr-pie-centro">Reporte de Aprobados y Reprobados</span>

                        <span class="apr-pie-der">

                            Generado: @fechaGeneracion

                            <span class="apr-pie-pagina"></span>

                        </span>

                    </div>

                </footer>

            }

            else

            {

                <div class="alert alert-warning text-center mb-0">

                    <i class="bi bi-exclamation-triangle"></i> No hay datos para los filtros seleccionados.

                </div>

            }

        </div>

    </div>



    @if (autoPrint)

    {

        <script>

            window.addEventListener('load', function () {

                setTimeout(function () { window.print(); }, 400);

            });

        </script>

    }

</body>

</html>

