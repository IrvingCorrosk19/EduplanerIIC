@model SchoolManager.Dtos.StudentIdCardDto?
@{
    var hasCard = Model != null;
    ViewData["Title"] = hasCard ? "Carnet Estudiantil - " + Model!.FullName : "Generar Carnet";
    Layout = "_SuperAdminLayout";
    var schoolName = ViewBag.SchoolName as string ?? "SchoolManager";
    var schoolLogoUrl = ViewBag.SchoolLogoUrl as string;
    var studentId = Model?.StudentId ?? (Guid)ViewBag.StudentId;
    var orientation = ViewBag.IdCardOrientation as string ?? "Vertical";
    var showQr = ViewBag.IdCardShowQr as bool? ?? true;
    var showPhoto = ViewBag.IdCardShowPhoto as bool? ?? true;
    var isVertical = string.Equals(orientation, "Vertical", StringComparison.OrdinalIgnoreCase);
    // Colores leídos desde configuración de la escuela (via ViewBag) para que la vista previa refleje los ajustes guardados
    var primaryColor = ViewBag.IdCardPrimaryColor as string ?? "#0D6EFD";
    var backgroundColor = ViewBag.IdCardBackgroundColor as string ?? "#FFFFFF";
    var textColor = ViewBag.IdCardTextColor as string ?? "#111111";
    var borderColor = "#e5e7eb";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');

    .carnet-preview-wrap {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 400px;
        padding: 2rem;
        background: #f5f5f5;
    }

    .carnet-container {
        width: @(isVertical ? "210px" : "342px");
        max-width: 100%;
        aspect-ratio: @(isVertical ? "54 / 86" : "86 / 54");
        max-height: @(isVertical ? "334px" : "216px");
        background: @backgroundColor;
        border-radius: 5px;
        padding: 6px;
        position: relative;
        overflow: hidden;
        border: 1px solid @borderColor;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
        color: @textColor;
        font-family: 'Inter', 'Segoe UI', Tahoma, sans-serif;
        display: flex;
        flex-direction: column;
    }

    .carnet-background {
        position: absolute;
        inset: 0;
        background-size: cover;
        background-position: center;
        opacity: 0.15;
        z-index: 0;
    }

    .carnet-header,
    .carnet-body,
    .carnet-footer {
        position: relative;
        z-index: 1;
    }

    .carnet-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 4px;
        padding: 4px 6px 4px 6px;
        background: @primaryColor;
        min-height: 28px;
        border-radius: 3px 3px 0 0;
    }

    .carnet-logo {
        max-width: 60px;
        max-height: 22px;
        object-fit: contain;
        filter: brightness(0) invert(1);
        opacity: 0.9;
    }

    .carnet-institution-name {
        font-size: 9pt;
        font-weight: 700;
        color: #ffffff;
        flex: 1;
        margin-left: 6px;
    }

    .carnet-body {
        display: flex;
        align-items: flex-start;
        gap: 6px;
        flex: 1;
        min-height: 0;
    }

    .carnet-photo {
        flex-shrink: 0;
        width: 60px;
        height: 72px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: 2px solid @primaryColor;
        border-radius: 4px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 8pt;
        font-weight: bold;
        box-shadow: 0 2px 6px rgba(0, 0, 0, 0.12);
    }

    .carnet-photo svg {
        width: 24px;
        height: 24px;
        opacity: 0.9;
        margin-bottom: 2px;
    }

    .carnet-info {
        flex: 1;
        min-width: 0;
    }

    .carnet-user-name {
        font-size: 11pt;
        font-weight: 700;
        color: @textColor;
        margin-bottom: 3px;
        line-height: 1.25;
    }

    .carnet-card-number {
        font-size: 9pt;
        color: @primaryColor;
        font-weight: 600;
        margin-bottom: 3px;
    }

    .carnet-details {
        font-size: 8pt;
        color: @textColor;
        line-height: 1.5;
        opacity: 0.95;
    }

    .carnet-detail-item {
        margin-bottom: 1px;
    }

    .carnet-qr-row {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 4px;
        margin-top: 4px;
    }

    .carnet-qr-label {
        font-size: 7pt;
        color: @textColor;
        opacity: 0.8;
    }

    /* QR generado como imagen (toDataURL es más fiable que toCanvas con estilos aplicados) */
    .carnet-qr-img {
        width: 44px;
        height: 44px;
        border: 2px solid @primaryColor;
        border-radius: 4px;
        background: white;
        display: block;
    }

    .carnet-back-qr-img {
        width: 80px;
        height: 80px;
        display: block;
        margin: 0 auto;
    }

    .carnet-footer {
        margin-top: auto;
        padding-top: 3px;
        border-top: 1px solid @borderColor;
        font-size: 7pt;
        color: @textColor;
        opacity: 0.7;
    }

    .print-actions {
        text-align: center;
        margin-top: 2rem;
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        justify-content: center;
    }

    .carnet-back-print {
        display: none;
        width: @(isVertical ? "210px" : "342px");
        max-width: 100%;
        aspect-ratio: @(isVertical ? "54 / 86" : "86 / 54");
        max-height: @(isVertical ? "334px" : "216px");
        margin: 0 auto;
        background: @backgroundColor;
        border-radius: 5px;
        padding: 12px;
        border: 1px solid @borderColor;
        font-family: 'Inter', 'Segoe UI', Tahoma, sans-serif;
        color: @textColor;
        text-align: center;
        box-sizing: border-box;
    }
    .carnet-back-print .carnet-back-qr { margin: 8px 0; text-align: center; }
    .carnet-back-print .carnet-back-school { font-weight: 700; font-size: 10pt; margin-bottom: 4px; }
    .carnet-back-print .carnet-back-text { font-size: 7pt; margin-bottom: 4px; }
    .carnet-back-print .carnet-back-number { font-size: 8pt; font-weight: 600; color: @primaryColor; }

    /* IMPRESION: la regla de tamaño de pagina se inyecta via JS (ver script al final) */

    @@media print {
        /* Forzar colores de fondo en impresión (desactivado por defecto en browsers) */
        * { -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; }

        /* Ocultar todo el contenido de la página */
        body * { visibility: hidden !important; }
        .print-actions { display: none !important; }

        /* ── Frente del carnet ─────────────────────────────── */
        .carnet-preview-wrap {
            visibility: visible !important;
            position: fixed !important;
            top: 0 !important; left: 0 !important;
            width: @(isVertical ? "54mm" : "86mm") !important;
            height: @(isVertical ? "86mm" : "54mm") !important;
            min-height: 0 !important;
            padding: 0 !important;
            margin: 0 !important;
            background: @backgroundColor !important;
            display: flex !important;
            align-items: flex-start !important;
            justify-content: flex-start !important;
        }
        .carnet-preview-wrap * { visibility: visible !important; }

        .carnet-container {
            width: @(isVertical ? "54mm" : "86mm") !important;
            height: @(isVertical ? "86mm" : "54mm") !important;
            max-width: none !important;
            max-height: none !important;
            aspect-ratio: unset !important;
            font-size: 7.5pt !important;
            line-height: 1.3 !important;
            border-radius: 2mm !important;
            box-shadow: none !important;
            border: 0.3mm solid rgba(0,0,0,0.15) !important;
            overflow: hidden !important;
            padding: 2mm !important;
            flex-shrink: 0 !important;
        }

        /* El carnet sólo tiene 1 página en impresión desde el browser.
           Para frente + reverso usar "Descargar PDF". */
        .carnet-back-print { display: none !important; }
    }
</style>

<div class="container-fluid">
    <div class="row">
        <div class="col-12 text-center mb-3">
            <h2><i class="fas fa-id-card"></i> Carnet Estudiantil</h2>
        </div>
    </div>

    @if (!hasCard)
    {
        <div class="row justify-content-center">
            <div class="col-md-6 text-center">
                <div class="alert alert-info">
                    <i class="fas fa-info-circle"></i>
                    Este estudiante no tiene un carnet activo. Haz clic en <strong>Generar Carnet</strong> para emitir uno.
                </div>
                <button id="btnGenerate" class="btn btn-primary btn-lg" onclick="generateCard('@studentId')">
                    <i class="fas fa-id-card"></i> Generar Carnet
                </button>
                <a href="/StudentIdCard/ui" class="btn btn-secondary btn-lg ms-2">
                    <i class="fas fa-arrow-left"></i> Volver
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="carnet-preview-wrap">
                    <div class="carnet-container" id="idCard">
                        <div class="carnet-background"
                             style="background-image:url('@(ViewBag.BackgroundImageUrl ?? "")')">
                        </div>
                        <div class="carnet-header">
                            @if (!string.IsNullOrEmpty(schoolLogoUrl))
                            {
                                <img src="@schoolLogoUrl" alt="Logo" class="carnet-logo" onerror="this.style.display='none'" />
                            }
                            <div class="carnet-institution-name">@schoolName</div>
                        </div>
                        <div class="carnet-body">
                            @if (showPhoto)
                            {
                                <div class="carnet-photo">
                                    @if (!string.IsNullOrEmpty(Model!.PhotoUrl))
                                    {
                                        <img src="@Model.PhotoUrl" alt="Foto" style="width:100%;height:100%;object-fit:cover;border-radius:2px;" />
                                    }
                                    else
                                    {
                                        <svg fill="currentColor" viewBox="0 0 24 24"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>
                                        <span>Sin Foto</span>
                                    }
                                </div>
                            }
                            <div class="carnet-info">
                                <div class="carnet-user-name">@Model.FullName</div>
                                <div class="carnet-card-number">Carnet: @Model.CardNumber</div>
                                <div class="carnet-details">
                                    <div class="carnet-detail-item"><strong>Grado:</strong> @Model.Grade</div>
                                    <div class="carnet-detail-item"><strong>Grupo:</strong> @Model.Group</div>
                                    <div class="carnet-detail-item"><strong>Jornada:</strong> @Model.Shift</div>
                                </div>
                                @if (showQr)
                                {
                                    @if (!string.IsNullOrEmpty(Model!.QrToken))
                                    {
                                        <div class="carnet-qr-row">
                                            <span class="carnet-qr-label">Escanea para verificar</span>
                                            <div class="carnet-qr">
                                                @* Imagen QR generada vía toDataURL (más fiable que toCanvas con CSS aplicado) *@
                                                <img id="qrImg" class="carnet-qr-img" data-qr-token="@Model.QrToken" alt="QR" />
                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        @* QR no disponible: token inexistente o expirado — regenerar carnet para obtener QR *@
                                        <div class="carnet-qr-row" style="justify-content:flex-end;margin-top:4px;">
                                            <small style="font-size:6pt;color:#dc3545;opacity:0.85;text-align:right;">QR no disponible<br/>Regenerar carnet</small>
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                        <div class="carnet-footer">
                            Emitido: @DateTime.UtcNow.ToString("dd/MM/yyyy")
                        </div>
                    </div>
                </div>
                @if (showQr && !string.IsNullOrEmpty(Model!.QrToken))
                {
                    <div class="carnet-back-print" id="carnetBackPrint">
                        <div class="carnet-back-qr">
                            <img id="qrImgBack" class="carnet-back-qr-img" data-qr-token="@Model.QrToken" alt="QR" />
                        </div>
                        <div class="carnet-back-school">@schoolName</div>
                        <div class="carnet-back-text">Escanea el código QR para verificar la información del carnet</div>
                        <div class="carnet-back-number">Carnet: @Model.CardNumber</div>
                    </div>
                }
                <div class="print-actions">
                    <a href="/StudentIdCard/ui/print/@Model.StudentId" class="btn btn-primary btn-lg" target="_blank">
                        <i class="fas fa-file-pdf"></i> Descargar PDF
                    </a>
                    <button type="button" class="btn btn-success btn-lg" onclick="window.print()">
                        <i class="fas fa-print"></i> Imprimir Carnet
                    </button>
                    <button type="button" class="btn btn-warning btn-lg" id="btnRegenerate" onclick="generateCard('@Model.StudentId')">
                        <i class="fas fa-sync-alt"></i> Regenerar Carnet
                    </button>
                    <a href="/StudentIdCard/ui" class="btn btn-secondary btn-lg">
                        <i class="fas fa-arrow-left"></i> Volver
                    </a>
                </div>
            </div>
        </div>
    }
</div>

@* Inyecta la regla de tamaño de pagina para impresion via JS (String.fromCharCode evita que Razor parsee el arroba como directiva) *@
<script>
    (function () {
        var s = document.createElement('style');
        s.textContent = String.fromCharCode(64) + 'page { size: @(isVertical ? "54mm 86mm" : "86mm 54mm"); margin: 0; }';
        document.head.appendChild(s);
    })();
</script>

@* qrcode.js — genera QR como Data URL y lo asigna a los img con data-qr-token *@
<script>
    function drawCarnetQR() {
        if (typeof QRCode === 'undefined') return;
        var imgs = document.querySelectorAll('img[data-qr-token]');
        imgs.forEach(function (img) {
            var token = img.getAttribute('data-qr-token');
            if (!token) return;
            var size = (img.id === 'qrImgBack') ? 80 : 44;
            QRCode.toDataURL(token, {
                width: size,
                margin: 1,
                color: { dark: '#000000', light: '#ffffff' }
            }, function (err, url) {
                if (err) { console.warn('[Carnet] Error generando QR:', err); return; }
                img.src = url;
            });
        });
    }
</script>
<script src="https://cdn.jsdelivr.net/npm/qrcode@1.5.4/build/qrcode.min.js" crossorigin="anonymous" onload="drawCarnetQR()"></script>
<script>
    @if (hasCard && showQr)
    {
        <text>
        if (typeof QRCode !== 'undefined') drawCarnetQR(); else window.addEventListener('load', function () { setTimeout(drawCarnetQR, 50); });
        </text>
    }

    function generateCard(id) {
        var btn = document.getElementById('btnGenerate') || document.getElementById('btnRegenerate');
        if (btn) {
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Generando...';
        }

        var antiforgeryInput = document.querySelector('input[name="__RequestVerificationToken"]');
        fetch('/StudentIdCard/api/generate/' + id, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': antiforgeryInput ? antiforgeryInput.value : ''
            }
        })
        .then(function (r) { return r.json(); })
        .then(function (data) {
            if (data && data.cardNumber) {
                window.location.href = '/StudentIdCard/ui/generate/' + id;
            } else {
                alert('Error: ' + (data.message || 'No se pudo generar el carnet.'));
                if (btn) {
                    btn.disabled = false;
                    btn.innerHTML = '<i class="fas fa-id-card"></i> Generar Carnet';
                }
            }
        })
        .catch(function () {
            alert('Error de red al generar el carnet.');
            if (btn) {
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-id-card"></i> Generar Carnet';
            }
        });
    }
</script>
