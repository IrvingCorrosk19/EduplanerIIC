@model SchoolManager.ViewModels.SuperAdminStudentDirectoryPageVm
@{
    ViewData["Title"] = "Directorio de estudiantes";
    Layout = "_SuperAdminLayout";
    var f = Model.Filter;
}
@Html.AntiForgeryToken()

<div class="card card-outline card-primary shadow-sm mb-4">
    <div class="card-header">
        <h3 class="card-title mb-0"><i class="fas fa-filter me-2"></i>Filtros</h3>
    </div>
    <div class="card-body">
        <form asp-action="StudentDirectory" method="get" id="filterForm">
            <div class="row g-3">
                <div class="col-lg-4 col-md-6">
                    <label class="form-label" for="Search">Buscar</label>
                    <input type="text" class="form-control" id="Search" name="Search" value="@f.Search"
                           placeholder="Nombre, apellido, correo o cédula" autocomplete="off" />
                </div>
                <div class="col-lg-4 col-md-6">
                    <label class="form-label" for="SchoolId">Escuela</label>
                    <select class="form-select" id="SchoolId" name="SchoolId" asp-items="Model.SchoolOptions"></select>
                </div>
                <div class="col-lg-4 col-md-6">
                    <label class="form-label" for="GradeId">Nivel / grado</label>
                    <select class="form-select" id="GradeId" name="GradeId" asp-items="Model.GradeOptions"></select>
                </div>
                <div class="col-lg-4 col-md-6">
                    <label class="form-label" for="GroupId">Grupo</label>
                    <select class="form-select" id="GroupId" name="GroupId" asp-items="Model.GroupOptions"></select>
                </div>
                <div class="col-lg-4 col-md-6">
                    <label class="form-label" for="ShiftId">Jornada (matrícula)</label>
                    <select class="form-select" id="ShiftId" name="ShiftId" asp-items="Model.ShiftOptions"></select>
                </div>
                <div class="col-lg-4 col-md-6">
                    <label class="form-label" for="UserStatus">Estado del usuario</label>
                    <select class="form-select" id="UserStatus" name="UserStatus">
                        @{
                            var statusOpts = new[] { ("", "Todos"), ("active", "Activo"), ("inactive", "Inactivo") };
                        }
                        @foreach (var o in statusOpts)
                        {
                            if (string.Equals(f.UserStatus ?? "", o.Item1, StringComparison.Ordinal))
                            {
                                <option value="@o.Item1" selected>@o.Item2</option>
                            }
                            else
                            {
                                <option value="@o.Item1">@o.Item2</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-12">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="OnlyWithoutAssignment" name="OnlyWithoutAssignment" value="true"
                               checked="@(f.OnlyWithoutAssignment)" />
                        <label class="form-check-label" for="OnlyWithoutAssignment">
                            Solo estudiantes sin matrícula activa (sin asignación de grado/grupo vigente)
                        </label>
                    </div>
                </div>
                <div class="col-12 d-flex flex-wrap gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-search me-1"></i> Aplicar filtros
                    </button>
                    <a asp-action="StudentDirectory" class="btn btn-outline-secondary">
                        <i class="fas fa-undo me-1"></i> Limpiar
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="d-flex flex-wrap justify-content-between align-items-center mb-3 gap-2">
    <p class="text-muted mb-0">
        <i class="fas fa-info-circle me-1"></i>
        @Model.Rows.Count registro(s). La jornada en matrícula y la del perfil del usuario pueden diferir.
    </p>
    <div class="input-group" style="max-width: 280px;">
        <span class="input-group-text"><i class="fas fa-search"></i></span>
        <input type="text" class="form-control" id="tableQuickFilter" placeholder="Filtrar filas visibles…" autocomplete="off" />
    </div>
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover table-striped align-middle mb-0" id="studentDirectoryTable">
            <thead class="table-light">
                <tr>
                    <th>Foto</th>
                    <th>Estudiante</th>
                    <th>Cédula</th>
                    <th>Correo</th>
                    <th>Escuela</th>
                    <th>Nivel / grado</th>
                    <th>Grupo</th>
                    <th>Jornada (matrícula)</th>
                    <th>Jornada (perfil)</th>
                    <th>Estado</th>
                    <th>Foto</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Rows.Any())
                {
                    <tr class="no-results-row">
                        <td colspan="11" class="text-center text-muted py-4">No hay resultados con los filtros actuales.</td>
                    </tr>
                }
                else
                {
                    foreach (var row in Model.Rows)
                    {
                        <tr data-search="@($"{row.FullName} {row.DocumentId} {row.Email} {row.SchoolName} {row.GradeLevelName} {row.GroupName} {row.ShiftName} {row.UserShift} {row.Status}")">
                            <td>
                                @if (!string.IsNullOrWhiteSpace(row.PhotoUrl))
                                {
                                    <img src="@row.PhotoUrl" alt="Foto @row.FullName" class="student-thumb" />
                                }
                                else
                                {
                                    <div class="student-thumb-placeholder"><i class="fas fa-user"></i></div>
                                }
                            </td>
                            <td>@row.FullName</td>
                            <td>@(string.IsNullOrWhiteSpace(row.DocumentId) ? "—" : row.DocumentId)</td>
                            <td><small>@row.Email</small></td>
                            <td>@(string.IsNullOrWhiteSpace(row.SchoolName) ? "—" : row.SchoolName)</td>
                            <td>
                                @if (row.HasActiveAssignment)
                                {
                                    @row.GradeLevelName
                                }
                                else
                                {
                                    <span class="text-warning"><i class="fas fa-exclamation-triangle me-1"></i>Sin matrícula</span>
                                }
                            </td>
                            <td>@(row.HasActiveAssignment && !string.IsNullOrWhiteSpace(row.GroupName) ? row.GroupName : "—")</td>
                            <td>@(string.IsNullOrWhiteSpace(row.ShiftName) ? "—" : row.ShiftName)</td>
                            <td>@(string.IsNullOrWhiteSpace(row.UserShift) ? "—" : row.UserShift)</td>
                            <td>
                                @if (string.Equals(row.Status, "active", StringComparison.OrdinalIgnoreCase))
                                {
                                    <span class="badge bg-success">Activo</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@(string.IsNullOrWhiteSpace(row.Status) ? "—" : row.Status)</span>
                                }
                            </td>
                            <td>
                                <button type="button"
                                        class="btn btn-sm btn-outline-primary btn-photo-manage"
                                        data-user-id="@row.UserId"
                                        data-full-name="@row.FullName"
                                        data-document-id="@row.DocumentId"
                                        data-grade="@(row.GradeLevelName ?? "Sin matrícula")"
                                        data-group="@(row.GroupName ?? "Sin grupo")"
                                        data-shift="@(row.ShiftName ?? row.UserShift ?? "Sin jornada")"
                                        data-photo-url="@row.PhotoUrl">
                                    <i class="fas fa-camera me-1"></i> Tomar/Subir
                                </button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="studentPhotoModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fas fa-camera me-2"></i>Foto del estudiante</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <div class="small text-muted mb-2" id="studentPhotoMeta"></div>
                <div class="text-center mb-3">
                    <img id="studentPhotoPreviewImg" src="" alt="Vista previa" class="img-thumbnail" style="max-width: 170px; max-height: 170px; object-fit: cover; display:none;" />
                    <div id="studentPhotoPreviewPlaceholder" class="student-thumb-placeholder mx-auto" style="width:170px;height:170px;">
                        <i class="fas fa-user fa-2x"></i>
                    </div>
                </div>
                <input type="file"
                       id="studentPhotoInput"
                       class="form-control"
                       accept=".jpg,.jpeg,.png,image/jpeg,image/png"
                       capture="environment" />
                <small class="text-muted">En tablet/celular abre la cámara trasera para tomar foto. También permite subir imagen.</small>
            </div>
            <div class="modal-footer">
                <button type="button" id="btnRemoveStudentPhoto" class="btn btn-outline-danger">
                    <i class="fas fa-trash me-1"></i> Eliminar foto
                </button>
                <button type="button" id="btnSaveStudentPhoto" class="btn btn-primary">
                    <i class="fas fa-upload me-1"></i> Guardar foto
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            var input = document.getElementById('tableQuickFilter');
            var currentStudentId = null;
            var currentPhotoUrl = null;
            var tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
            var token = tokenInput ? tokenInput.value : '';
            var photoModalEl = document.getElementById('studentPhotoModal');
            var photoModal = photoModalEl ? new bootstrap.Modal(photoModalEl) : null;
            var photoInput = document.getElementById('studentPhotoInput');
            var previewImg = document.getElementById('studentPhotoPreviewImg');
            var previewPlaceholder = document.getElementById('studentPhotoPreviewPlaceholder');
            var meta = document.getElementById('studentPhotoMeta');
            var btnSave = document.getElementById('btnSaveStudentPhoto');
            var btnRemove = document.getElementById('btnRemoveStudentPhoto');
            if (!input) return;

            input.addEventListener('input', function () {
                var q = (this.value || '').toLowerCase().trim();
                var rows = document.querySelectorAll('#studentDirectoryTable tbody tr[data-search]');
                rows.forEach(function (tr) {
                    var hay = (tr.getAttribute('data-search') || '').toLowerCase();
                    tr.style.display = !q || hay.indexOf(q) !== -1 ? '' : 'none';
                });
            });

            function setPreview(url) {
                currentPhotoUrl = url || '';
                if (currentPhotoUrl) {
                    previewImg.src = currentPhotoUrl;
                    previewImg.style.display = '';
                    previewPlaceholder.style.display = 'none';
                    btnRemove.disabled = false;
                } else {
                    previewImg.src = '';
                    previewImg.style.display = 'none';
                    previewPlaceholder.style.display = 'flex';
                    btnRemove.disabled = true;
                }
            }

            function applyThumbToTable(userId, url) {
                var btn = document.querySelector('.btn-photo-manage[data-user-id="' + userId + '"]');
                if (!btn) return;
                btn.setAttribute('data-photo-url', url || '');
                var row = btn.closest('tr');
                if (!row) return;
                var thumbCell = row.children[0];
                if (!thumbCell) return;
                if (url) {
                    thumbCell.innerHTML = '<img src="' + url + '" alt="Foto estudiante" class="student-thumb" />';
                } else {
                    thumbCell.innerHTML = '<div class="student-thumb-placeholder"><i class="fas fa-user"></i></div>';
                }
            }

            document.addEventListener('click', function (ev) {
                var btn = ev.target.closest('.btn-photo-manage');
                if (!btn || !photoModal) return;
                currentStudentId = btn.getAttribute('data-user-id');
                setPreview(btn.getAttribute('data-photo-url') || '');
                photoInput.value = '';
                meta.textContent = 'Estudiante: ' + (btn.getAttribute('data-full-name') || '') +
                    ' | Cédula: ' + (btn.getAttribute('data-document-id') || '—') +
                    ' | Grado: ' + (btn.getAttribute('data-grade') || '—') +
                    ' | Grupo: ' + (btn.getAttribute('data-group') || '—') +
                    ' | Jornada: ' + (btn.getAttribute('data-shift') || '—');
                photoModal.show();
            });

            photoInput.addEventListener('change', function () {
                var file = this.files && this.files[0];
                if (!file) return;
                var objectUrl = URL.createObjectURL(file);
                previewImg.src = objectUrl;
                previewImg.style.display = '';
                previewPlaceholder.style.display = 'none';
            });

            btnSave.addEventListener('click', async function () {
                if (!currentStudentId) return;
                var file = photoInput.files && photoInput.files[0];
                if (!file) {
                    alert('Seleccione o tome una foto primero.');
                    return;
                }
                var fd = new FormData();
                fd.append('userId', currentStudentId);
                fd.append('photo', file);
                fd.append('__RequestVerificationToken', token);
                btnSave.disabled = true;
                try {
                    var res = await fetch('/SuperAdmin/StudentDirectoryUpdatePhoto', {
                        method: 'POST',
                        body: fd,
                        credentials: 'same-origin'
                    });
                    var data = await res.json();
                    if (!data.success) {
                        alert(data.message || 'No se pudo guardar la foto.');
                        return;
                    }
                    setPreview(data.photoUrl || '');
                    applyThumbToTable(currentStudentId, data.photoUrl || '');
                    photoInput.value = '';
                } catch {
                    alert('Error de red al guardar la foto.');
                } finally {
                    btnSave.disabled = false;
                }
            });

            btnRemove.addEventListener('click', async function () {
                if (!currentStudentId) return;
                if (!confirm('¿Eliminar foto del estudiante?')) return;
                var fd = new FormData();
                fd.append('userId', currentStudentId);
                fd.append('__RequestVerificationToken', token);
                btnRemove.disabled = true;
                try {
                    var res = await fetch('/SuperAdmin/StudentDirectoryRemovePhoto', {
                        method: 'POST',
                        body: fd,
                        credentials: 'same-origin'
                    });
                    var data = await res.json();
                    if (!data.success) {
                        alert(data.message || 'No se pudo eliminar la foto.');
                        return;
                    }
                    setPreview('');
                    applyThumbToTable(currentStudentId, '');
                } catch {
                    alert('Error de red al eliminar la foto.');
                } finally {
                    btnRemove.disabled = false;
                }
            });
        })();
    </script>

    <style>
        .student-thumb {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            object-fit: cover;
            border: 1px solid #dbe4f0;
            box-shadow: 0 1px 2px rgba(0,0,0,.08);
        }
        .student-thumb-placeholder {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            border: 1px dashed #cbd5e1;
            color: #94a3b8;
            background: #f8fafc;
            display: flex;
            align-items: center;
            justify-content: center;
        }
    </style>
}
